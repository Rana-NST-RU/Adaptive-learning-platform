# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─────────────────────────────────────────────────────────────
# PostgreSQL (Local Docker)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=alos_user
POSTGRES_PASSWORD=alos_password
POSTGRES_DB=alos_db
DATABASE_URL="postgresql://alos_user:alos_password@localhost:5432/alos_db?schema=public"

# ─────────────────────────────────────────────────────────────
# Redis (Local Docker / Upstash for production)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production (Upstash):
# REDIS_URL=rediss://:your-upstash-password@your-upstash-endpoint:6380

# ─────────────────────────────────────────────────────────────
# Neo4j (Local Docker / AuraDB for production)
# ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=alos_neo4j_password
# Production (AuraDB):
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-aura-password

# ─────────────────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-change-in-prod
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-chars-change-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# Google OAuth 2.0
# Get from: console.cloud.google.com → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ─────────────────────────────────────────────────────────────
# Phone OTP (MSG91)
# Get from: msg91.com → Dashboard → API → Auth Key
# Free: 100 SMS/month
# ─────────────────────────────────────────────────────────────
MSG91_API_KEY=your-msg91-api-key
MSG91_SENDER_ID=ALOSSN
MSG91_TEMPLATE_ID=your-otp-template-id

# ─────────────────────────────────────────────────────────────
# Groq LLM API
# Get from: console.groq.com → API Keys
# Free tier: 30 req/min, 14400 req/day
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama3-70b-8192

# ─────────────────────────────────────────────────────────────
# Next.js Frontend
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-minimum-32-chars-change-in-prod

# ─────────────────────────────────────────────────────────────
# ML Service
# ─────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ENVIRONMENT=development
