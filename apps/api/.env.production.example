# ─────────────────────────────────────────────────────────────────────────────
# ALOS API — Production Environment Variables Template
# Copy to .env before deploying. NEVER commit this file with real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# ── PostgreSQL (Prisma) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/alos_db?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_32_char_random_secret
JWT_EXPIRY=7d

# ── Firebase (Phone Auth) ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Neo4j Aura ────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── LLM (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama3-8b-8192
