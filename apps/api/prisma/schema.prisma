generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String?           @unique
  phone            String?           @unique
  googleId         String?           @unique
  name             String
  avatar           String?
  role             Role              @default(STUDENT)
  provider         AuthProvider      @default(EMAIL)
  isVerified       Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  masteries        ConceptMastery[]
  events           LearningEvent[]
  sessions         LearningSession[]
  streak           LearningStreak?
  questionAttempts QuestionAttempt[]
  recommendations  Recommendation[]
  refreshTokens    RefreshToken[]
  profile          UserProfile?
  achievements     UserAchievement[]

  @@index([role])           // admin user-list filter
  @@index([isActive])       // admin active-user filter
  @@index([createdAt])      // admin recent-registrations
  @@map("users")
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalXP         Int      @default(0)
  currentLevel    Int      @default(1)
  preferredDomain Domain   @default(DSA)
  dailyGoalMins   Int      @default(30)
  timezone        String   @default("Asia/Kolkata")
  bio             String?
  institution     String?
  targetExam      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model LearningSession {
  id              String          @id @default(cuid())
  userId          String
  startedAt       DateTime        @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  conceptsVisited String[]
  questionsCount  Int             @default(0)
  correctCount    Int             @default(0)
  xpEarned        Int             @default(0)
  domain          Domain?
  deviceInfo      Json?
  events          LearningEvent[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("learning_sessions")
}

model LearningEvent {
  id          String           @id @default(cuid())
  userId      String
  sessionId   String?
  eventType   EventType
  conceptId   String
  conceptName String
  domain      Domain           @default(DSA)
  payload     Json
  timestamp   DateTime         @default(now())
  session     LearningSession? @relation(fields: [sessionId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([userId, conceptId])
  @@index([userId, eventType])
  @@index([conceptId])
  @@map("learning_events")
}

model ConceptMastery {
  id                 String    @id @default(cuid())
  userId             String
  conceptId          String
  conceptName        String
  domain             Domain    @default(DSA)
  masteryScore       Float     @default(0.0)
  masteryLevel       Int       @default(0)
  retentionScore     Float     @default(1.0)
  lastRevisionAt     DateTime?
  nextRevisionDue    DateTime?
  revisionCount      Int       @default(0)
  memoryStrength     Float     @default(0.0)
  fsrsDifficulty     Float     @default(5.0) // FSRS-4.5: personalised difficulty 1-10
  totalAttempts      Int       @default(0)
  correctAttempts    Int       @default(0)
  incorrectAttempts  Int       @default(0)
  hintsUsed          Int       @default(0)
  avgTimePerQuestion Float?
  firstAttemptAt     DateTime?
  lastAttemptAt      DateTime?
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId])
  @@index([userId, masteryScore])
  @@index([userId, nextRevisionDue])
  @@index([conceptId])
  @@map("concept_masteries")
}

model LearningStreak {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate  DateTime?
  totalActiveDays Int       @default(0)
  streakFreezes   Int       @default(2)
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("learning_streaks")
}

model Question {
  id             String            @id @default(cuid())
  conceptId      String
  conceptName    String
  domain         Domain            @default(DSA)
  content        String
  questionType   QuestionType      @default(MCQ)
  difficulty     Difficulty        @default(MEDIUM)
  options        Json?
  correctAnswer  String
  explanation    String
  hints          String[]
  tags           String[]
  codeSnippet    String?
  language       String?
  generatedByLLM Boolean           @default(true)
  llmModel       String?
  isValidated    Boolean           @default(false)
  isActive       Boolean           @default(true)
  isFlagged      Boolean           @default(false)
  flagReason     String?
  flaggedBy      String?           // userId who flagged it
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  attempts       QuestionAttempt[]

  @@index([conceptId, difficulty])
  @@index([domain, difficulty])
  @@index([isFlagged])
  @@map("questions")
}

model QuestionAttempt {
  id          String   @id @default(cuid())
  questionId  String
  userId      String
  sessionId   String?
  answer      String
  isCorrect   Boolean
  timeTakenMs Int
  hintsUsed   Int      @default(0)
  score       Float    @default(0.0)
  confidenceRating Int?          // FSRS grade 1-4 (Again/Hard/Good/Easy)
  timestamp   DateTime @default(now())
  question    Question @relation(fields: [questionId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, questionId])
  @@index([userId, timestamp])
  @@index([questionId])
  @@index([isCorrect])      // accuracy aggregation
  @@map("question_attempts")
}

model Recommendation {
  id          String             @id @default(cuid())
  userId      String
  conceptId   String
  conceptName String
  type        RecommendationType
  reason      String
  priority    Int                @default(5)
  isActedOn   Boolean            @default(false)
  actedOnAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priority])
  @@index([userId, isActedOn])
  @@map("recommendations")
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  type       String   // e.g. 'FIRST_ANSWER', 'STREAK_7', 'EXPERT_CONCEPT'
  metadata   Json?    // optional context: { conceptName: string } etc.
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("user_achievements")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String                     // admin/teacher who performed action
  actorName  String
  action     String                     // e.g. ROLE_CHANGE, QUESTION_EDIT, MASTERY_OVERRIDE, QUESTION_FLAG
  targetType String                     // USER | QUESTION | MASTERY
  targetId   String
  targetName String?
  before     Json?                      // previous state
  after      Json?                      // new state
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
  @@index([action])
  @@map("admin_audit_logs")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  PHONE
}

enum EventType {
  SESSION_START
  SESSION_END
  CONCEPT_VIEWED
  QUESTION_ATTEMPTED
  QUESTION_CORRECT
  QUESTION_INCORRECT
  HINT_USED
  VIDEO_STARTED
  VIDEO_COMPLETED
  VIDEO_PAUSED
  REVISION_STARTED
  REVISION_COMPLETED
  STREAK_UPDATED
  MASTERY_UPDATED
  PATH_PROGRESSED
  ASSESSMENT_STARTED
  ASSESSMENT_COMPLETED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  CODE_SNIPPET
  MATCH_FOLLOWING
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Domain {
  DSA
  SYSTEM_DESIGN
  BOTH
}

enum RecommendationType {
  LEARN_NEW
  REVISE
  PRACTICE
  ASSESSMENT
  WATCH_VIDEO
}
